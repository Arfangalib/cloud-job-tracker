NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/cloud-job-tracker
CLIENT_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
REFRESH_TOKEN_PEPPER=replace_with_another_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
APIFY_TOKEN=
APIFY_JOB_ACTOR_ID=worldunboxer~rapid-linkedin-scraper
APIFY_WEBHOOK_SECRET=replace_with_a_shared_webhook_secret
PUBLIC_API_URL=http://localhost:4000
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_SCORING_MODEL=gpt-5.4-mini
OPENAI_TAILOR_MODEL=gpt-5.4
# File storage for uploaded resumes and generated documents.
# STORAGE_DRIVER=local writes under UPLOAD_DIR; STORAGE_DRIVER=s3 uses S3_BUCKET.
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
S3_BUCKET=
AWS_REGION=us-east-1
